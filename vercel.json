{
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "dev/devadmin/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "dev/davadmin/static/(.*)", "dest": "/staticfiles/$1" },
    { "src": "/(.*)", "dest": "dev/devadmin/wsgi.py" }
  ]
}
